# Supabase (REST API)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_..."

# LINE Messaging API
# Webhook 署名検証に使うチャネルシークレット
LINE_CHANNEL_SECRET=""
# push / profile 取得に使うチャネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=""

# Cron（/api/cron/reminders を保護する Bearer トークン）
# 呼び出し側は Authorization: Bearer <CRON_SECRET> を付与する
CRON_SECRET=""

# ダウンロードリンク生成のベース URL。
# Vercel 環境では自動注入されるため通常は設定不要（ローカル検証時のみ）。
# 例: your-app.vercel.app（スキームは付けない）
VERCEL_PROJECT_PRODUCTION_URL=""

# ── 認証ゲート（workspace-hub の JWT を JWKS 検証）──────────────────
# 既定は「監視モード」。AUTH_ENFORCE を設定しない限り挙動は変わらない
# （/api/v1/* は従来どおり無認証で通り、検証結果を console に記録するのみ）。

# enforce（ブロック）を有効化するときだけ "on" にする。
# 未設定 / "on" 以外 = 監視モード（ブロックしない）。
AUTH_ENFORCE=""

# JWKS の取得先（workspace-hub の公開エンドポイント）。
# 未設定時の既定: https://auth.utinc.dev/.well-known/jwks.json
JWKS_URL=""

# 期待する発行者（workspace-hub の EXPECTED_ISSUER と一致させる）。
# 未設定時の既定: https://auth.utinc.dev
AUTH_EXPECTED_ISSUER=""

# このアプリを表す下流システムキー（JWT の systems[] と突き合わせ）。
# workspace-hub SYSTEM_CATALOG のキー 'lpd' と一致させる。
# 未設定時の既定: lpd
AUTH_SYSTEM_KEY=""

# ── テナントデータ分離 ────────────────────────────────────────────
# JWT を持たない経路（LINE Webhook / cron / サーバー間 messages/send）の既定テナント。
# ログインユーザーの /api/v1/* は wh_token(JWT) の tenant_id claim で解決するため不要。
# 未設定時の既定: utinc のテナントID（現状唯一の利用者）。
# 将来テナントが増えても、これら無 JWT 経路の既定先としてのみ使う。
DEFAULT_TENANT_ID=""

# ── 単体販売版（STANDALONE）モード ────────────────────────────────
# 既定（未設定）= プラットフォーム版＝現状挙動を一切変えない（完全後方互換）。
# 単体版で運用するときだけ true にする。サーバー側は STANDALONE を正本とし、
# クライアント露出が要る箇所のために NEXT_PUBLIC_STANDALONE も同値で設定する。
#
# 単体版 ON で変わる点（すべて isStandalone() ガード下）:
#   - proxy が wh ゲートではなく Supabase Auth（自前ログイン）でアクセスを保護する。
#   - resolveTenantId が wh JWT ではなく下記 STANDALONE_TENANT_ID を返す。
#   - ヘッダの再ログインアイコンが wh SSO ではなく自前 /login を指す。
STANDALONE=""
NEXT_PUBLIC_STANDALONE=""

# 単体版の固定テナントID（単一顧客＝1 テナント）。STANDALONE=true のとき必須。
# wh JWT が無くても、データ分離コードがこの固定値で成立する。
# 未設定だと resolveTenantId が null（fail-closed）を返し、クロステナントは出さない。
STANDALONE_TENANT_ID=""

# ── 単体版ログイン（Supabase Auth・anon/publishable キー）─────────────
# STANDALONE=true のとき必須。/login の email/password 認証と proxy のセッション
# 検証に使う「認証専用」クライアント（データ I/O は従来どおり service_role）。
# どちらも公開して良い値（ブラウザに焼き込まれる・RLS 前提）。
# プラットフォーム版（STANDALONE 未設定）では一切参照されないため未設定で無害。
#   - URL は SUPABASE_URL と同じプロジェクトの URL。
#   - キーは publishable（sb_publishable_...）または旧 anon キー。
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
